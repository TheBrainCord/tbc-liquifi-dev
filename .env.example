# Site
NEXT_PUBLIC_SITE_URL=https://liquifi.cash
NEXT_PUBLIC_SUPPORT_PHONE=+91 XXXXXXXXXX

# Supabase — create project at supabase.com, then copy from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SMS — sign up at 2factor.in → copy your API key from the dashboard
# Leave blank in local dev: OTP will be printed to server logs instead
TWOFACTOR_API_KEY=

# WhatsApp admin notifications — https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Setup (2 min): Save +34 644 59 63 42 in WhatsApp → send "I allow callmebot to send me messages"
# → you'll receive your API key on WhatsApp. Paste it here.
# Leave blank in local dev: notification will be printed to server logs instead
CALLMEBOT_WHATSAPP_API_KEY=
WHATSAPP_NOTIFY_PHONE=917829816599

# Email admin notifications (runs in parallel with WhatsApp) — https://resend.com
# Setup (2 min): sign up at resend.com → API Keys → Create API Key → paste here
# Free plan: 3,000 emails/month. Notifications go to ADMIN_NOTIFY_EMAIL.
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=thebraincordservices@gmail.com

# CA email for ITR filing bookings — set to your CA friend's email
CA_NOTIFY_EMAIL=ca@example.com

# AI Chat — Claude API (Anthropic)
# Get key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Bot — Meta WhatsApp Cloud API (free, no per-message cost)
# Setup: https://developers.facebook.com → WhatsApp → Getting Started
# 1. Create Meta Business app → Add WhatsApp product
# 2. Copy Phone Number ID and temporary access token below
# 3. Set webhook URL to: https://liquifi.cash/api/whatsapp/webhook
# 4. Set WHATSAPP_VERIFY_TOKEN to any random string (you choose it)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=liquifi-whatsapp-verify-2024
